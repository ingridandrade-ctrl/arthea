generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  AGENT
}

enum LeadSource {
  WHATSAPP
  WEBSITE
  MANUAL
  REFERRAL
  QUIZ
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
}

enum MessageSender {
  LEAD
  AI
  AGENT
}

enum AutomationTrigger {
  STAGE_CHANGE
  TIME_AFTER_STAGE
  NEW_LEAD
  NO_RESPONSE
}

enum AutomationAction {
  SEND_WHATSAPP
  MOVE_STAGE
  ASSIGN_AGENT
  CREATE_REMINDER
}

enum Recurrence {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ContractStatus {
  ACTIVE
  PAUSED
  CANCELED
  COMPLETED
}

enum ClientType {
  ACTIVE
  INACTIVE
  TEMPORARY
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum ExpenseCategory {
  TOOL
  SALARY
  TAX
  MARKETING
  INFRASTRUCTURE
  OTHER
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  role           Role           @default(AGENT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deals          Deal[]
  messages       Message[]      @relation("SentByUser")
  activities     Activity[]     @relation("UserActivities")
  assignedTasks  Task[]         @relation("AssignedTasks")
  createdTasks   Task[]         @relation("CreatedTasks")
  notifications  Notification[]
}

model Service {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  description String?
  icon        String?
  color       String       @default("#6366f1")
  isActive    Boolean      @default(true)
  basePrice     Float?
  setupFee      Float?
  createdAt   DateTime     @default(now())
  leads       LeadService[]
  deals       Deal[]
  contracts Contract[]
  invoices  Invoice[]
}

model Lead {
  id             String          @id @default(cuid())
  name           String
  phone          String          @unique
  email          String?
  company        String?
  source         LeadSource      @default(WHATSAPP)
  status         LeadStatus      @default(NEW)
  tags           String[]
  score          Int             @default(0)
  notes          String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  quizAnswers    Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  services       LeadService[]
  deals          Deal[]
  conversations  Conversation[]
  automationLogs AutomationLog[]
  activities     Activity[]
  tasks          Task[]
  contracts Contract[]
  invoices Invoice[]

  @@index([status])
  @@index([phone])
}

// Many-to-many: Lead <-> Service
model LeadService {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([leadId, serviceId])
  @@index([leadId])
  @@index([serviceId])
}

// Single pipeline — no more serviceId
model Pipeline {
  id        String          @id @default(cuid())
  name      String
  stages    PipelineStage[]
  createdAt DateTime        @default(now())
}

model PipelineStage {
  id         String     @id @default(cuid())
  name       String
  order      Int
  color      String     @default("#6366f1")
  pipelineId String
  pipeline   Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals      Deal[]
  followUps  FollowUp[]

  @@index([pipelineId])
}

model Deal {
  id                String        @id @default(cuid())
  title             String
  value             Float?
  probability       Int?
  expectedCloseDate DateTime?
  diagnosticNotes   Json?
  leadId            String
  lead              Lead          @relation(fields: [leadId], references: [id])
  serviceId         String
  service           Service       @relation(fields: [serviceId], references: [id])
  stageId           String
  stage             PipelineStage @relation(fields: [stageId], references: [id])
  assignedToId      String?
  assignedTo        User?         @relation(fields: [assignedToId], references: [id])
  closedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  activities        Activity[]
  tasks             Task[]
  followUps         FollowUp[]
  contract Contract?

  @@index([serviceId])
  @@index([stageId])
  @@index([leadId])
  @@index([assignedToId])
}

model FollowUp {
  id              String    @id @default(cuid())
  dealId          String
  deal            Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stageId         String
  stage           PipelineStage @relation(fields: [stageId], references: [id])
  order           Int
  delayHours      Int
  messageTemplate String
  channel         String    @default("whatsapp")
  isAutomatic     Boolean   @default(false)
  status          String    @default("pending") // pending, sent, skipped
  scheduledAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([dealId])
  @@index([stageId])
  @@index([status, scheduledAt])
}

model FollowUpTemplate {
  id              String   @id @default(cuid())
  name            String
  stageOrder      Int
  followUpOrder   Int
  channel         String   @default("whatsapp")
  messageTemplate String
  isAutomatic     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([stageOrder, followUpOrder])
}

model Conversation {
  id            String    @id @default(cuid())
  leadId        String
  lead          Lead      @relation(fields: [leadId], references: [id])
  isAiActive    Boolean   @default(true)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  messages      Message[]

  @@index([leadId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content        String
  sender         MessageSender
  sentByUserId   String?
  sentByUser     User?        @relation("SentByUser", fields: [sentByUserId], references: [id])
  evolutionMsgId String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model Automation {
  id            String            @id @default(cuid())
  name          String
  description   String?
  trigger       AutomationTrigger
  triggerConfig Json
  action        AutomationAction
  actionConfig  Json
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  logs          AutomationLog[]

  @@index([trigger])
}

model AutomationLog {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  leadId       String
  lead         Lead       @relation(fields: [leadId], references: [id])
  status       String
  executedAt   DateTime   @default(now())
  result       Json?

  @@index([automationId])
  @@index([leadId])
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  userId      String?
  user        User?    @relation("UserActivities", fields: [userId], references: [id])

  @@index([leadId, createdAt])
  @@index([dealId, createdAt])
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?
  completed    Boolean   @default(false)
  completedAt  DateTime?
  priority     String    @default("medium")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id])
  dealId       String?
  deal         Deal?     @relation(fields: [dealId], references: [id])
  assignedToId String?
  assignedTo   User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdById  String?
  createdBy    User?     @relation("CreatedTasks", fields: [createdById], references: [id])

  @@index([assignedToId, completed])
  @@index([dueDate])
  @@index([leadId])
  @@index([dealId])
}

model Contract {
  id             String         @id @default(cuid())
  number         String         @unique
  dealId         String?        @unique
  deal           Deal?          @relation(fields: [dealId], references: [id])
  leadId         String
  lead           Lead           @relation(fields: [leadId], references: [id])
  serviceId      String?
  service        Service?       @relation(fields: [serviceId], references: [id])
  serviceIds     String[]       @default([])
  monthlyValue   Float
  setupValue     Float?
  durationMonths Int            @default(12)
  recurrence     Recurrence     @default(MONTHLY)
  status         ContractStatus @default(ACTIVE)
  clientType     ClientType     @default(ACTIVE)
  niche          String?
  tags           String[]
  paymentLink    String?
  startDate      DateTime
  endDate        DateTime?
  paymentDay     Int            @default(10)
  invoices       Invoice[]
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([clientType])
  @@index([leadId])
}

model Invoice {
  id                 String        @id @default(cuid())
  number             String        @unique
  contractId         String?
  contract           Contract?     @relation(fields: [contractId], references: [id])
  leadId             String
  lead               Lead          @relation(fields: [leadId], references: [id])
  serviceId          String?
  service            Service?      @relation(fields: [serviceId], references: [id])
  serviceIds         String[]      @default([])
  amount             Float
  status             InvoiceStatus @default(PENDING)
  dueDate            DateTime
  paidAt             DateTime?
  paymentMethod      String?
  paymentLink        String?
  description        String?
  installmentNumber  Int?
  totalInstallments  Int?
  invoiceIssued      Boolean       @default(false)
  invoiceNumber      String?
  invoiceIssuedAt    DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status, dueDate])
  @@index([leadId])
  @@index([serviceId])
}

model Expense {
  id          String           @id @default(cuid())
  description String
  amount      Float
  category    ExpenseCategory  @default(OTHER)
  date        DateTime
  recurring   Boolean          @default(false)
  notes       String?
  tags        String[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([date])
  @@index([category])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read])
}
