# Database
DATABASE_URL="postgresql://user:password@localhost:5432/arthea"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Anthropic (Claude API)
ANTHROPIC_API_KEY="sk-ant-..."

# ─── WhatsApp Provider ──────────────────────────────────────────
# Choose: "official" (Meta Cloud API) or "evolution" (Evolution API)
WHATSAPP_PROVIDER="official"

# ─── WhatsApp Business Cloud API (Meta Official) ────────────────
# Get these at: https://developers.facebook.com/apps → WhatsApp
WHATSAPP_API_TOKEN="your-meta-access-token"
WHATSAPP_PHONE_ID="your-phone-number-id"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# ─── Evolution API (alternative, self-hosted) ───────────────────
# Only needed if WHATSAPP_PROVIDER="evolution"
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="your-evolution-api-key"
EVOLUTION_INSTANCE="arthea"

# Cron Secret (para proteger endpoint de automacoes)
CRON_SECRET="your-cron-secret"

# ─── Modulo Financeiro ──────────────────────────────────────────
# Hash bcrypt da senha de acesso ao financeiro
# Gere com: node -e "require('bcryptjs').hash('suaSenha', 10).then(console.log)"
FINANCE_PASSWORD_HASH="$2b$10$..."
